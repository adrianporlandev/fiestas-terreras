    class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce"
  >
    <svg
      class="w-6 h-6 text-white/60"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
    </svg>
  </div>

  <script is:inline>
    const dateBadgeEl = document.getElementById("hero-date-badge");
    const dateDescriptionEl = document.getElementById("hero-date-description");
    const dayEl = document.getElementById("hero-cd-days");
    const hourEl = document.getElementById("hero-cd-hours");
    const minuteEl = document.getElementById("hero-cd-minutes");
    const secondEl = document.getElementById("hero-cd-seconds");

    function getFirstWeekendStart(year) {
      const augustFirst = new Date(year, 7, 1, 0, 0, 0, 0);
      const daysUntilSaturday = (6 - augustFirst.getDay() + 7) % 7;
      const firstSaturday = new Date(
        year,
        7,
        1 + daysUntilSaturday,
        0,
        0,
        0,
        0,
      );
      const firstFriday = new Date(firstSaturday);
      firstFriday.setDate(firstSaturday.getDate() - 1);
      return firstFriday;
    }

    function getNextFiestaStart(now) {
      let candidate = getFirstWeekendStart(now.getFullYear());
      if (now.getTime() >= candidate.getTime()) {
        candidate = getFirstWeekendStart(now.getFullYear() + 1);
      }
      return candidate;
    }

    function formatRange(startDate) {
      const endDate = new Date(startDate);
      endDate.setDate(startDate.getDate() + 2);

      const monthFormatter = new Intl.DateTimeFormat("es-ES", {
        month: "long",
      });
      const startMonth = monthFormatter.format(startDate);
      const endMonth = monthFormatter.format(endDate);

      if (startMonth === endMonth) {
        return `Del ${startDate.getDate()} al ${endDate.getDate()} de ${startMonth}`;
      }

      return `Del ${startDate.getDate()} de ${startMonth} al ${endDate.getDate()} de ${endMonth}`;
    }

    const targetDate = getNextFiestaStart(new Date());
    const dateLabel = formatRange(targetDate);

    if (dateBadgeEl) {
      dateBadgeEl.innerHTML = `<span class="mr-2">📅</span>${dateLabel}`;
    }

    if (dateDescriptionEl) {
      dateDescriptionEl.textContent = `${dateLabel}. Música, tradición y diversión para toda la familia.`;
    }

    function pad(value) {
      return String(value).padStart(2, "0");
    }

    function renderCountdown() {
      const now = new Date();
      let diff = Math.max(0, targetDate.getTime() - now.getTime());

      const days = Math.floor(diff / (1000 * 60 * 60 * 24));
      diff -= days * (1000 * 60 * 60 * 24);
      const hours = Math.floor(diff / (1000 * 60 * 60));
      diff -= hours * (1000 * 60 * 60);
      const minutes = Math.floor(diff / (1000 * 60));
      diff -= minutes * (1000 * 60);
      const seconds = Math.floor(diff / 1000);

      if (dayEl) dayEl.textContent = pad(days);
      if (hourEl) hourEl.textContent = pad(hours);
      if (minuteEl) minuteEl.textContent = pad(minutes);
      if (secondEl) secondEl.textContent = pad(seconds);
    }

    renderCountdown();
    setInterval(renderCountdown, 1000);
  </script>
</section>

