---
import { programaFiestas } from "../data/programaPreFiestas";

const resaltarTextoEntreComillas = (texto: string) =>
  texto.replace(/"([^"]+)"/g, '"<strong class="font-bold text-gray-900">$1</strong>"');

const obtenerNumeroDia = (fecha: string) => fecha.match(/\d{1,2}/)?.[0] ?? "";

const artistaPrefiesta = {
  nombre: "D'Antaño",
  imagen: "/fiestas/dantano.jpg",
  instagram: "https://www.instagram.com/explore/search/keyword/?q=danta%C3%B1o",
};
---
<section id="programa" class="w-full py-20 relative">
  <!-- Background decoration -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute -top-40 -right-40 w-80 h-80 bg-gradient-to-br from-rose-100 to-rose-200 rounded-full opacity-30 blur-3xl"></div>
    <div class="absolute -bottom-40 -left-40 w-80 h-80 bg-gradient-to-br from-blue-100 to-blue-200 rounded-full opacity-30 blur-3xl"></div>
  </div>
  
  <div class="flex justify-center w-full relative z-10">
    <div class="container px-4 md:px-6 max-w-6xl w-full text-center">
      <div class="space-y-6 mb-16">
        <div class="inline-flex items-center px-4 py-2 rounded-full bg-gradient-to-r from-rose-500 to-rose-600 text-white text-sm font-medium shadow-lg">
          <span class="mr-2">📅</span>
          PreFiestas
        </div>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight bg-gradient-to-r from-gray-800 to-rose-600 bg-clip-text text-transparent">
          🎉 Programa PreFiestas
        </h2>
        <p class="max-w-3xl mx-auto text-lg md:text-xl text-gray-600 leading-relaxed">
          Descubre el horario de actividades del dia de las PreFiestas. ¡Te esperamos para celebrar juntos!
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {programaFiestas.map((dia) => (
          <div class={`group bg-white border border-gray-200 p-8 rounded-3xl shadow-lg hover:shadow-2xl transition-all duration-500 text-left transform hover:-translate-y-2 relative overflow-hidden ${programaFiestas.length === 1 ? "md:col-span-2 lg:col-span-1 lg:col-start-2" : ""}`}>
            <!-- Background decoration for card -->
            <div class={`absolute top-0 right-0 w-20 h-20 bg-gradient-to-br ${dia.theme.bg} rounded-full opacity-50 -translate-y-10 translate-x-10`}></div>

            <div class="relative z-10">
              <div class="mb-6 text-center">
                <div class={`w-12 h-12 bg-gradient-to-br ${dia.theme.badge} rounded-full flex items-center justify-center shadow-lg mx-auto mb-3`}>
                  <span class="text-white font-bold text-lg">{obtenerNumeroDia(dia.fecha)}</span>
                </div>
                <div>
                  <h3 class="text-xl font-bold text-gray-800">{dia.nombre}</h3>
                  <p class="text-sm text-gray-500">{dia.fecha}</p>
                </div>
              </div>

              <ul class="space-y-3 text-gray-700 text-sm leading-relaxed">
                {dia.eventos.map((evento, index) => {
                  const mostrarHora = index === 0 || evento.hora !== dia.eventos[index - 1].hora;

                  return (
                    <li class="flex items-start gap-3 group/item hover:bg-gray-50 p-2 rounded-lg transition-colors duration-200">
                      <span class={`w-2 h-2 ${dia.theme.dot} rounded-full mt-2 flex-shrink-0`}></span>
                      <div>
                        {mostrarHora ? (
                          <>
                            <strong class={dia.theme.time}>{evento.hora}:</strong>{" "}
                            <span set:html={resaltarTextoEntreComillas(evento.descripcion)}></span>
                          </>
                        ) : (
                          <span set:html={resaltarTextoEntreComillas(evento.descripcion)}></span>
                        )}
                      </div>
                    </li>
                  );
                })}
              </ul>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-12">
        <p class="text-xs md:text-sm uppercase tracking-[0.2em] text-gray-500 mb-6">Artista Invitado</p>
        <div class="group flex flex-col items-center">
          <a
            href={artistaPrefiesta.instagram}
            target="_blank"
            rel="noopener noreferrer"
            class="relative"
          >
            <div
              class="relative w-32 h-32 md:w-40 md:h-40 rounded-full overflow-hidden shadow-xl border-4 border-white group-hover:border-rose-500 transition-all duration-500 transform group-hover:scale-105 group-hover:shadow-2xl"
            >
              <img
                src={artistaPrefiesta.imagen}
                alt={`Actuacion de ${artistaPrefiesta.nombre} en las PreFiestas de Las Terreras`}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                loading="lazy"
                onerror="this.onerror=null;this.src='/placeholder-logo.svg';this.classList.add('bg-gray-100','border-dashed');"
              />
              <div
                class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-all duration-500"
              >
              </div>
              <div
                class="absolute top-2 right-2 w-8 h-8 bg-white/20 backdrop-blur-sm rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-500 transform scale-0 group-hover:scale-100"
              >
                <svg
                  class="w-4 h-4 text-white"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
                  ></path>
                </svg>
              </div>
            </div>
          </a>
          <span
            class="font-bold text-lg md:text-xl text-gray-800 mt-4 group-hover:text-rose-600 transition-colors duration-300"
            >{artistaPrefiesta.nombre}</span
          >
          <p class="text-sm text-gray-500 mt-1">Instagram</p>
        </div>
      </div>
    </div>
  </div>
</section>
