---
const {
  title,
  description = "Fiestas de Las Terreras: programa, galería, patrocinadores y contacto. Celebra con nosotros los días 1, 2 y 3 de Agosto en Las Terreras.",
} = Astro.props;

const siteTitle = "Fiestas de Las Terreras";
const pageTitle = title ? `${title} | ${siteTitle}` : siteTitle;
const siteUrl = Astro.site ?? new URL("https://lasterreras.pages.dev");
const canonicalUrl = new URL(Astro.url.pathname, siteUrl);
const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteTitle,
  alternateName: [
    "Las Terreras",
    "Fiestas Terreras 2026",
    "Fiestas Terreras",
    "Fiestas de Las Terreras 2026",
  ],
  url: siteUrl.href,
  description,
  inLanguage: "es-ES",
};
const isHomePage = Astro.url.pathname === "/" || Astro.url.pathname === "";
---

<meta name="description" content={description} />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<title>{pageTitle}</title>
<meta
  name="robots"
  content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
/>
<meta
  name="keywords"
  content="Fiestas, Las Terreras, Programa, Galería, Patrocinadores, Contacto, Agosto, Música, Tradición, Eventos, Pueblo"
/>
<meta name="author" content="Adrian Porlan" />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalUrl.href} />
<meta property="og:site_name" content={siteTitle} />
<meta property="og:locale" content="es_ES" />
<meta
  property="og:image"
  content="https://lasterreras.pages.dev/fiestas/cristo.jpg"
/>
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content="/fiestas/cristo.jpg" />
<meta name="twitter:url" content={canonicalUrl.href} />
<meta
  name="google-site-verification"
  content="ECBuJCOdB9dP2zDE6M5weGH60SJQUziFLDRVf3UUjnE"
/>
<link
  rel="preload"
  as="image"
  href="/fondo-terreras-1280.webp"
  imagesrcset="/fondo-terreras-1280.webp 1280w, /fondo-terreras-1920.webp 1920w"
  imagesizes="100vw"
/>
{
  isHomePage && (
    <script
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
    />
  )
}
<link rel="canonical" href={canonicalUrl.href} />
<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
