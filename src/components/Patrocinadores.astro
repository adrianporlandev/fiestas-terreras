<section id="patrocinadores" class="w-full py-12 md:py-24 lg:py-32 relative">
  <div class="flex justify-center w-full">
    <div class="container px-4 md:px-6 max-w-5xl w-full text-center">
      <div class="space-y-4">
        <h2 class="text-3xl font-bold tracking-tighter sm:text-4xl md:text-5xl">
          Nuestros Patrocinadores
        </h2>
        <p
          class="mx-auto max-w-225 text-muted-foreground md:text-xl/relaxed lg:text-base/relaxed xl:text-xl/relaxed"
        >
          Gracias a su apoyo, estas fiestas son posibles.
        </p>
      </div>
      <div class="grid gap-6 py-8 sm:grid-cols-2 xl:grid-cols-4">
        {
          featuredSponsors.map((sponsor) => (
            <a
              href={sponsor.href}
              target={sponsor.href.startsWith("http") ? "_blank" : "_self"}
              rel={
                sponsor.href.startsWith("http")
                  ? "noopener noreferrer"
                  : undefined
              }
              class="group flex items-center justify-center rounded-2xl border border-slate-200 bg-slate-50 p-4 shadow-sm transition-transform duration-300 hover:-translate-y-1 hover:shadow-md"
            >
              <img
                src={sponsor.src}
                width={sponsor.width}
                height={sponsor.height}
                alt={sponsor.alt}
                class="h-32 w-full max-w-65 object-contain transition-transform duration-300 group-hover:scale-105 sm:h-36 md:h-40 lg:h-44"
                onerror="this.onerror=null;this.src='/placeholder-logo.svg';this.classList.add('bg-gray-100','border-dashed');"
              />
            </a>
          ))
        }
      </div>
      <div class="grid gap-5 py-8 grid-cols-2 sm:grid-cols-3 lg:grid-cols-4">
        {
          sponsors.map((sponsor) => (
            <a
              href={sponsor.href}
              target={sponsor.href.startsWith("http") ? "_blank" : "_self"}
              rel={
                sponsor.href.startsWith("http")
                  ? "noopener noreferrer"
                  : undefined
              }
              class="group flex items-center justify-center rounded-xl border border-slate-200 bg-white p-3 shadow-sm transition-transform duration-300 hover:-translate-y-1 hover:shadow-md"
            >
              <img
                src={sponsor.src}
                width="320"
                height="160"
                alt={sponsor.alt}
                class="h-24 w-full max-w-50 object-contain transition-transform duration-300 group-hover:scale-105 sm:h-28 md:h-32"
                onerror="this.onerror=null;this.src='/placeholder-logo.svg';this.classList.add('bg-gray-100','border-dashed');"
              />
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>
