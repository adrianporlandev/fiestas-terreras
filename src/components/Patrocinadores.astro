---

<section id="patrocinadores" class="w-full py-20 relative">
  <!-- Background decoration -->
  <div class="absolute inset-0 pointer-events-none">
    <div
      class="absolute top-0 right-0 w-96 h-96 bg-linear-to-br from-rose-100 to-rose-200 rounded-full opacity-30 blur-3xl"
    >
    </div>
    <div
      class="absolute bottom-0 left-0 w-96 h-96 bg-linear-to-br from-blue-100 to-blue-200 rounded-full opacity-30 blur-3xl"
    >
    </div>
  </div>

  <div class="flex justify-center w-full relative z-10">
    <div class="container px-4 md:px-6 max-w-6xl w-full text-center">
      <div class="space-y-6 mb-16">
        <div
          class="inline-flex items-center px-4 py-2 rounded-full bg-linear-to-r from-rose-500 to-rose-600 text-white text-sm font-medium shadow-lg"
        >
          <span class="mr-2">🤝</span>
          Patrocinadores
        </div>
        <h2
          class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight bg-linear-to-r from-gray-800 to-rose-600 bg-clip-text text-transparent"
        >
          Nuestros Patrocinadores
        </h2>
        <p
          class="mx-auto max-w-225 text-lg md:text-xl text-gray-600 leading-relaxed"
        >
          Gracias a su apoyo, estas fiestas son posibles.
        </p>
      </div>
      <div class="grid gap-6 py-8 sm:grid-cols-2 xl:grid-cols-4">
        {
          featuredSponsors.map((sponsor) => (
            <a
              href={sponsor.href}
              target={sponsor.href.startsWith("http") ? "_blank" : "_self"}
              rel={
                sponsor.href.startsWith("http")
                  ? "noopener noreferrer"
                  : undefined
              }
              class="group flex items-center justify-center rounded-2xl border border-slate-200 bg-slate-50 p-4 shadow-sm transition-transform duration-300 hover:-translate-y-1 hover:shadow-md"
            >
              <img
                src={sponsor.src}
                width={sponsor.width}
                height={sponsor.height}
                alt={sponsor.alt}
                class={`w-full object-contain transition-transform duration-300 group-hover:scale-105 ${
                  sponsor.isPortrait
                    ? "h-56 max-w-65 sm:h-64 md:h-72 lg:h-80"
                    : "h-32 max-w-65 sm:h-36 md:h-40 lg:h-44"
                }`}
                onerror="this.onerror=null;this.src='/placeholder-logo.svg';this.classList.add('bg-gray-100','border-dashed');"
              />
            </a>
          ))
        }
      </div>
      <div class="grid gap-5 py-8 grid-cols-2 sm:grid-cols-3 lg:grid-cols-4">
        {
          sponsors.map((sponsor) => (
            <a
              href={sponsor.href}
              target={sponsor.href.startsWith("http") ? "_blank" : "_self"}
              rel={
                sponsor.href.startsWith("http")
                  ? "noopener noreferrer"
                  : undefined
              }
              class="group flex items-center justify-center rounded-xl border border-slate-200 bg-white p-3 shadow-sm transition-transform duration-300 hover:-translate-y-1 hover:shadow-md"
            >
              <img
                src={sponsor.src}
                width="320"
                height="160"
                alt={sponsor.alt}
                class="h-24 w-full max-w-50 object-contain transition-transform duration-300 group-hover:scale-105 sm:h-28 md:h-32"
                onerror="this.onerror=null;this.src='/placeholder-logo.svg';this.classList.add('bg-gray-100','border-dashed');"
              />
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>
