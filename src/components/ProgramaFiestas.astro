---
import { programaFiestas } from "../data/programaFiestas";

const resaltarTextoEntreComillas = (texto: string) =>
  texto.replace(/"([^"]+)"/g, '"<strong class="font-bold text-gray-900">$1</strong>"');
---
<section id="programa" class="w-full py-20 bg-gradient-to-br from-white via-gray-50 to-gray-100 relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute -top-40 -right-40 w-80 h-80 bg-gradient-to-br from-rose-100 to-rose-200 rounded-full opacity-30 blur-3xl"></div>
    <div class="absolute -bottom-40 -left-40 w-80 h-80 bg-gradient-to-br from-blue-100 to-blue-200 rounded-full opacity-30 blur-3xl"></div>
  </div>
  
  <div class="flex justify-center w-full relative z-10">
    <div class="container px-4 md:px-6 max-w-6xl w-full text-center">
      <div class="space-y-6 mb-16">
        <div class="inline-flex items-center px-4 py-2 rounded-full bg-gradient-to-r from-rose-500 to-rose-600 text-white text-sm font-medium shadow-lg">
          <span class="mr-2">📅</span>
          Programa Completo
        </div>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight bg-gradient-to-r from-gray-800 to-rose-600 bg-clip-text text-transparent">
          🎉 Programa de Fiestas
        </h2>
        <p class="max-w-3xl mx-auto text-lg md:text-xl text-gray-600 leading-relaxed">
          Descubre todas las actividades que hemos preparado para ti. ¡Te esperamos para celebrar juntos!
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {programaFiestas.map((dia) => (
          <div class="group bg-white border border-gray-200 p-8 rounded-3xl shadow-lg hover:shadow-2xl transition-all duration-500 text-left transform hover:-translate-y-2 relative overflow-hidden">
            <!-- Background decoration for card -->
            <div class={`absolute top-0 right-0 w-20 h-20 bg-gradient-to-br ${dia.theme.bg} rounded-full opacity-50 -translate-y-10 translate-x-10`}></div>

            <div class="relative z-10">
              <div class="flex items-center gap-3 mb-6">
                <div class={`w-12 h-12 bg-gradient-to-br ${dia.theme.badge} rounded-full flex items-center justify-center shadow-lg`}>
                  <span class="text-white font-bold text-lg">{dia.numero}</span>
                </div>
                <div>
                  <h3 class="text-xl font-bold text-gray-800">{dia.nombre}</h3>
                  <p class="text-sm text-gray-500">{dia.fecha}</p>
                </div>
              </div>

              <ul class="space-y-3 text-gray-700 text-sm leading-relaxed">
                {dia.eventos.map((evento, index) => {
                  const mostrarHora = index === 0 || evento.hora !== dia.eventos[index - 1].hora;

                  return (
                    <li class="flex items-start gap-3 group/item hover:bg-gray-50 p-2 rounded-lg transition-colors duration-200">
                      <span class={`w-2 h-2 ${dia.theme.dot} rounded-full mt-2 flex-shrink-0`}></span>
                      <div>
                        {mostrarHora ? (
                          <>
                            <strong class={dia.theme.time}>{evento.hora}:</strong>{" "}
                            <span set:html={resaltarTextoEntreComillas(evento.descripcion)}></span>
                          </>
                        ) : (
                          <span set:html={resaltarTextoEntreComillas(evento.descripcion)}></span>
                        )}
                      </div>
                    </li>
                  );
                })}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
